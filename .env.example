# Use either DATABASE_URL or separate DB_* variables.
# Example:
# DATABASE_URL=postgres://user:password@host:5432/dbname

DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=

# Optional: enable SSL for providers that require it.
# Values: true/false
DB_SSL=false

# Optional safety switch.
# In production strict mode is enabled automatically (NODE_ENV=production),
# and server will fail to start if DB is unavailable instead of falling back to file.
# You can also force strict DB mode in any environment:
# REQUIRE_DATABASE=true

# Optional: brute-force protection for admin login.
# After N failed attempts from one IP, login endpoint is blocked for BLOCK_MS.
# ADMIN_BRUTE_FORCE_MAX_ATTEMPTS=5
# ADMIN_BRUTE_FORCE_WINDOW_MS=900000
# ADMIN_BRUTE_FORCE_BLOCK_MS=900000
